{
    "name": "phphd/exceptional-matcher",
    "description": "Match exceptions to the properties that originated them",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Yevhen Sidelnyk",
            "email": "zsidelnik@gmail.com"
        },
        {
            "name": "Jesus – Savior and Son of God"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "webmozart/assert": "^1.12.1",
        "phphd/exception-toolkit": "^1.2",
        "composer-runtime-api": "^2.0"
    },
    "conflict": {
        "symfony/validator": "<6.0 || >8.4",
        "symfony/http-kernel": "<6.0 || >8.4",
        "symfony/dependency-injection": "<6.2 || >8.4",
        "symfony/messenger": "<6.4 || >8.4",
        "symfony/console": "<6.0 || >8.4"
    },
    "require-dev": {
        "symfony/validator": ">=6.0",
        "symfony/http-kernel": ">=6.0",
        "symfony/dependency-injection": ">=6.2",
        "symfony/messenger": ">=6.4",
        "symfony/uid": ">=6.0",
        "symfony/var-dumper": ">=6.0",
        "bamarni/composer-bin-plugin": "^1.8",
        "phphd/coding-standard": "~1.0.0",
        "phpunit/phpunit": "^10.5.46",
        "nyholm/symfony-bundle-test": "^3.1",
        "phpbench/phpbench": "^1.2.6",
        "composer/class-map-generator": "^1.1",
        "symfony/console": ">=6.0"
    },
    "suggest": {
        "symfony/validator": "Install Validator component to format matched exceptions into ConstraintViolationList format",
        "symfony/messenger": "Install Messenger component to match with a middleware",
        "symfony/console": "Install Console component to lint the exception mappings with the lint:exceptional-matcher command",
        "composer/class-map-generator": "Install class map generator to discover classes for the lint:exceptional-matcher command",
        "amphp/amp": "Install AMP package to match multiple exceptions at once"
    },
    "replace": {
        "phphd/exceptional-validation": "*",
        "phphd/exceptional-validation-bundle": "*"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/phphd/coding-standard",
            "no-api": true
        }
    ],
    "autoload": {
        "psr-4": {
            "PhPhD\\": "src",
            "PhPhD\\ExceptionalMatcher\\Upgrade\\": "upgrade"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhPhD\\ExceptionalMatcher\\Tests\\": "tests"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "composer bin psalm update --ansi"
        ],
        "ci:pack": [
            "@ci:ecs",
            "@ci:rector",
            "@ci:static",
            "@ci:unit-test",
            "@ci:integration-test"
        ],
        "ci:ecs": "vendor/bin/ecs check",
        "ci:ecs-fix": "vendor/bin/ecs check --fix",
        "ci:rector": "vendor/bin/rector process --dry-run",
        "ci:rector-fix": "vendor/bin/rector process",
        "ci:static": [
            "@ci:phpstan",
            "@ci:psalm"
        ],
        "ci:phpstan": "vendor/bin/phpstan analyze",
        "ci:psalm": "vendor-bin/psalm/psalm",
        "ci:test": "vendor/bin/phpunit --testdox --colors=always",
        "ci:unit-test": "vendor/bin/phpunit --testdox --colors=always --testsuite=Unit",
        "ci:integration-test": "vendor/bin/phpunit --testdox --colors=always --testsuite=Integration"
    },
    "config": {
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true
        }
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": false,
            "forward-command": true
        }
    }
}
